# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=servicetickets
DB_USER=postgres
DB_PASSWORD=yourpassword

# Server
PORT=3001
SESSION_SECRET=<zufälliger-64-zeichen-string>
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Email (IMAP for receiving, SMTP for sending)
SMTP_HOST=send.one.com
SMTP_PORT=465
SMTP_USER=ticket@example.com
SMTP_PASS=your_password
SMTP_FROM=Service <ticket@example.com>

IMAP_HOST=imap.one.com
IMAP_PORT=993
IMAP_USER=ticket@example.com
IMAP_PASS=your_password

# Legacy Gmail support (used as fallback if SMTP_*/IMAP_* not set)
# GMAIL_USER=your@gmail.com
# GMAIL_APP_PASSWORD=your_app_password

# Anthropic API (Claude AI – optional)
ANTHROPIC_API_KEY=

# Sentry (optional – Fehler-Monitoring)
SENTRY_DSN=
